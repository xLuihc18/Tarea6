<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Multicines Cinestar Perú">
    <link rel="shortcut icon" href="~/img/varios/favicon.ico">
    @* El tilde ~ le dice a ASP.NET que busque en wwwroot *@
    <link href="~/css/estilos.css" rel="stylesheet" type="text/css">
    <title>@ViewData["Title"] - Multicines Cinestar</title>
</head>
<body>

    <header>
        <nav class="nav-sec">
            <a href="/">Inicio</a>&nbsp;&nbsp;l&nbsp;&nbsp;
            <a href="#">Quiénes somos</a>&nbsp;&nbsp;l&nbsp;&nbsp;
            <a href="#">Trabaja con nosotros</a>&nbsp;&nbsp;l&nbsp;&nbsp;
            <a href="#" target="_blank">Consulta tu comprobante</a>&nbsp;&nbsp;l&nbsp;&nbsp;
            <a href="#" class="anchorLink">Contáctenos</a>
        </nav>
        <div class="area-logo">
            <a href="/"><img src="~/img/varios/logo-cinestar.png" /></a>
        </div>
        <nav class="menu">
            <span class="img-social">
                <a href="http://www.facebook.com/multicinestar" target="_blank"><img src="~/img/varios/ico-face.png" /></a>
                <a href="http://www.twitter.com/multicinestar" target="_blank"><img src="~/img/varios/ico-twitter.png" /></a>
            </span>
            <span class="social">Síguenos en: </span>
            <ul class="menu-principal">
                @* Usamos asp-controller y asp-action para que el niño no se pierda *@
                <li class="menu-item"><a asp-controller="Cinestar" asp-action="Peliculas" asp-route-id="1">Cartelera</a></li>
                <li class="menu-item"><a asp-controller="Cinestar" asp-action="Peliculas" asp-route-id="2">Próximos estrenos</a></li>
                <li class="menu-item"><a href="#">Star Card</a></li>
                <li class="menu-item"><a asp-controller="Cinestar" asp-action="Cines">Nuestros Cines</a></li>
                <li class="menu-item"><a href="#">Ventas Corporativas</a></li>
                <li class="menu-item"><a href="#">Promociones</a></li>
                <li class="menu-item"><a href="#">Blog</a></li>
            </ul>
        </nav>
        <div class="slider"></div>
        <div class="papaya">
            <a href="#" target="_blank"><img src="~/img/varios/bg-papaya.jpg" /></a>
        </div>
    </header>

    @* --- AQUÍ OCURRE LA MAGIA --- *@
    @RenderBody()
    @* El dibujo (Cines o Películas) se mete aquí adentro *@

    <footer>
        <div class="contenido-footer">
            <p>Copyright © 2026 ® Multicines CINESTAR - Todos los Derechos Reservados</p>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
